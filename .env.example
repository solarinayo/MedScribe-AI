# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://...
# Optional: more tolerant JWT iat/exp (default 10)
# CLERK_JWT_LEEWAY=10
# Unhandled JWT errors in logs: CLERK_JWT_DEBUG=1

# Frontend: in `npm run dev` the app calls http://127.0.0.1:8000 by default (avoids Next proxy
# dropping Authorization for Clerk). Override with NEXT_PUBLIC_API_ORIGIN, or set
# NEXT_PUBLIC_USE_DEV_PROXY=1 to use the Next rewrite in next.config.ts.
# NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:8000
# NEXT_PUBLIC_USE_DEV_PROXY=1

# Subscription gate (frontend build / dev):
# Leave unset or empty = any signed-in user can use /product (Clerk free tier is fine).
# Set to a Billing plan id (e.g. premium_subscription) when Clerk Billing is enabled.
# NEXT_PUBLIC_CLERK_REQUIRED_PLAN=premium_subscription

# LLM: prefer OpenRouter (unified API, OpenAI-compatible) — if set, it is used over OPENAI_API_KEY
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional OpenRouter settings (defaults work for local dev on :3000):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_REFERER=http://127.0.0.1:3000
# OPENROUTER_X_TITLE=MedScribe AI

# If you are not using OpenRouter, set OpenAI directly:
# OPENAI_API_KEY=sk-...

# Chat model (OpenRouter uses names like openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, etc.)
OPENAI_MODEL=openai/gpt-4o-mini

# GCP (local / CI — not injected into the container by default)
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=europe-west1
