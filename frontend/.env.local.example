NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# `next dev` proxies /api to FastAPI (see next.config.ts rewrites). Leave
# NEXT_PUBLIC_API_ORIGIN unset. Set it only to call the API from another
# origin (CORS) instead of the proxy.
# NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:8000

# Optional: require a Clerk Billing plan on /product (omit for sign-in only).
# NEXT_PUBLIC_CLERK_REQUIRED_PLAN=premium_subscription
